<mujoco model="world">
    <option gravity = "0 0 0" />
    <asset>
        <model name="table_model" file="table.xml"/>
        <model name="my_robot" file="my-robot/my_robot.xml"/>
        <model name="plate_model" file="plate.xml"/>
    </asset>
    <worldbody>
        <light name="top" pos="0 0 5"/>
        <geom type="plane" size="5 5 .1" pos="0 0 0"/>
        <body name="table" pos="0 0 0.051">
            <attach model="table_model" prefix="table_import"/>
        </body>
        <body name="my_robot" pos="0 0 0.05">
            <attach model="my_robot" prefix="my_robot_import"/>
        </body>
        <body name="plate" pos="0.2 0 0.13">
            <attach model="plate_model" prefix="plate_import"/>
        </body>
    </worldbody>
</mujoco>