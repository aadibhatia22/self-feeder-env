<mujoco model="my-robot">
  <compiler angle="radian" meshdir="assets"/>

  <asset>
    <mesh name="part_1" content_type="model/stl" file="part_1.stl"/>
    <mesh name="part_2" content_type="model/stl" file="part_2.stl"/>
    <mesh name="part_3" content_type="model/stl" file="part_3.stl"/>
    <mesh name="part_4" content_type="model/stl" file="part_4.stl"/>
    <mesh name="part_5" content_type="model/stl" file="part_5.stl"/>
  </asset>

  <worldbody>
    <body name ="arm" pos="0 0 0.05">
      <geom name="part_1" type="mesh" rgba="0.615686 0.811765 0.929412 1" mesh="part_1"/>
      <body name="rotation from base" euler="0 0 0">

        <joint/>
          <geom name="part_2" type="mesh" rgba="0.929412 0.709804 0.384314 1" mesh="part_2"/>
          <body name="second rotation">
            <joint name="second" type="hinge" axis="0 -1 0" pos="0 0 .13" />


              <geom name="part_3" type="mesh" rgba="0.494118 0.752941 0.482353 1" mesh="part_3"/>
            <body>
              <joint name="third" type="hinge" axis="0 1 0" pos="0 0 .23" />
              <geom name="part_4" type="mesh" rgba="0.858824 0.47451 0.443137 1" mesh="part_4"/>
              <geom name="part_5" type="mesh" rgba="0.678431 0.560784 0.835294 1" mesh="part_5"/>
            </body>

          </body>
      </body>
    </body>

    

  </worldbody>
  <actuator>
      <motor joint="second" ctrlrange="-.002 .002" ctrllimited="true" gear=".5"/>
      <motor joint="third" ctrlrange="-.002 .002" ctrllimited="true" gear=".5"/>
    </actuator>
</mujoco>
