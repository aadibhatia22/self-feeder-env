   "source": [
    "import mujoco\n",
    "\n",
    "# Load the URDF and compile it into a MuJoCo model\n",
    "model = mujoco.MjModel.from_xml_path(\"xml_models/base-camera-stand/robot.urdf\")\n",
    "\n",
    "# Save it as a native MuJoCo XML file\n",
    "mujoco.mj_saveLastXML(\"robot.xml\", model)"
   ]
  }
