<mujoco model="world">
    <option gravity = "0 0 9.80665" />

    <visual>
        <global offwidth="1920" offheight="1080" />
    </visual>
  
    <!-- Loading the base camera stand model -->
    <asset>
        <model name="base_camera_stand" file="base-camera-stand/robot.xml"/>
        <model name="table" file="table/table.xml"/>

        <mesh name = "plate_visual" file="plate/PLATE.stl"/>
        <mesh name = "plate_collision" file="plate/MUJOCO_PLATE.stl"/>

        <texture name="apriltag_36h11_0"
            type="2d"
            file="april_tag/tag36h11-0.png"/>
        <material name="apriltag_36h11_0_material"
            texture="apriltag_36h11_0"
            texrepeat="1 1"
            reflectance="0"/>

    </asset>
   
   
    <worldbody>
        <light diffuse="1 1 1" pos="0 0 2" dir="0 0 -1"/>
        <geom type="plane" size="10 10 0.1" pos="0 0 0"/>
        <body name="table" pos="0 0 0.051">
            <attach model="table" prefix="1"/>
        </body>
        <body name="base_camera_stand_instance" pos="0 0 0.125">
            <attach model="base_camera_stand" prefix="1"/>
        </body>
        <body name ="apriltag_3611_0" pos="-0.165 -0.1 0.1655">
             <!-- 60 mm AprilTag, visual-only, placed just above the plate -->
            <geom name="apriltag_36h11_0"
                type="plane"
                pos="0 0 0"
                size="0.03 0.03 0.001"
                material="apriltag_36h11_0_material"
                contype="0"
                conaffinity="0"/>
        </body>
        <body name="plate" pos="0 0 0.15">
            <!-- Visible mesh only -->
            <geom type="mesh"
                mesh="plate_visual"
                contype="0"
                conaffinity="0"
                />

            <!-- Collision mesh only -->
            <geom type="mesh"
                mesh="plate_collision"
                contype="1"
                conaffinity="1"
                rgba="0 0 0 0"/>
        </body>

        <!--CALCULATE THE CAMERA POSITION EXACTLY-->
        <camera name="emeet_c960_camera"
                pos="0 0 0.50"
                euler="0 0 0"
                projection="perspective"
                fovy="52.23"
                resolution="1920 1080"/>

    </worldbody>
</mujoco>
